# Neon connection for the stockgame-scoped role. SHARED DB — the role must have
# zero privileges outside coingame_* tables.
DATABASE_URL=

# Per-source signing key issued by botcity /developer AFTER you connect the game.
# Verifies launch tokens, signs /spine and /close pushes, signs our session cookie.
ROOMS_SIGNING_KEY=

# This app's public origin, e.g. https://stockgame.hadmoney.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret for GET /api/sweep (Vercel cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
