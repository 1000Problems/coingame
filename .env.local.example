# Neon connection for the coingame-scoped role. SHARED DB — the role must have
# zero privileges outside coingame_* tables.
DATABASE_URL=

# Per-source signing key issued by botcity /developer AFTER you connect the game.
# Verifies launch tokens, signs /spine and /close pushes, signs our session cookie.
ROOMS_SIGNING_KEY=

# That's the whole list. No cron secret (the /api/sweep sweeper is open and
# idempotent — a Cowork scheduled task pings it daily) and no app-URL var
# (scripts/mint-test-token.mjs defaults to localhost; set APP_URL to override).
